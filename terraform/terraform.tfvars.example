# Copy this file to terraform.tfvars and update the values.
region          = "us-east-1"
instance_type   = "t3.micro"
# IMPORTANT: Use an ABSOLUTE path to your *PUBLIC* key (ends with .pub)
public_key_path = "/ABSOLUTE/PATH/TO/your_public_key.pub"

# (Optional) Lock SSH to your IP/corporate CIDR block
allow_ssh_cidr  = "0.0.0.0/0"
allow_http_cidr = "0.0.0.0/0"
